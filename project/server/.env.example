### Copy this file to `server/.env` and replace the placeholders with your secret values.
# Your Google API key (do NOT commit this file to git)
GOOGLE_API_KEY=AIza...your_google_api_key_here
# The Google AI Studio model id (example: chat-bison-001). Replace with the model you created in Google AI Studio.
GOOGLE_MODEL_ID=chat-bison-001
